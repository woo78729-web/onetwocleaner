# 開發環境預設走 Vite proxy 到 Laravel（/api）
# 生產環境請改為 Zeabur 上的 Laravel API 網域
VITE_API_URL=/api

# Google Maps JavaScript API（Places Autocomplete）
# 請在 Google Cloud Console 啟用「Maps JavaScript API」與「Places API (New)」
# 舊版 Places API 自 2025/3 起新專案已無法使用
# HTTP referrer 需加入：http://127.0.0.1:8000/*、http://localhost:5173/*、正式網域/*
VITE_GOOGLE_MAPS_API_KEY=
