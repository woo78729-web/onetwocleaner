{
  "info": {
    "name": "冷氣清洗派班與帳務管理 API",
    "description": "Laravel Sanctum RESTful API 測試集合",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://127.0.0.1:8000/api"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "scheduleId",
      "value": ""
    },
    {
      "key": "loginAccount",
      "value": ""
    },
    {
      "key": "loginPassword",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('token', json.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"account\": \"{{loginAccount}}\",\n  \"password\": \"{{loginPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/login"
          }
        },
        {
          "name": "Login (Employee)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('token', json.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"account\": \"{{loginAccount}}\",\n  \"password\": \"{{loginPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/login"
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/me"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/logout"
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Create Employee",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"account\": \"emp-new\",\n  \"password\": \"{{loginPassword}}\",\n  \"name\": \"員工三\"\n}"
            },
            "url": "{{baseUrl}}/admin/users"
          }
        },
        {
          "name": "Create Schedule",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": 3,\n  \"work_date\": \"2026-06-29\",\n  \"customer_address\": \"台北市中山區南京東路一段1號\",\n  \"customer_phone\": \"0911000111\",\n  \"task_details\": \"11離11000\",\n  \"notes\": \"測試班表\"\n}"
            },
            "url": "{{baseUrl}}/admin/schedules"
          }
        },
        {
          "name": "List Schedules",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/schedules?date_from=2026-06-29&date_to=2026-06-30&has_report=0&page=1&per_page=10",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "schedules"],
              "query": [
                { "key": "date_from", "value": "2026-06-29" },
                { "key": "date_to", "value": "2026-06-30" },
                { "key": "has_report", "value": "0" },
                { "key": "page", "value": "1" },
                { "key": "per_page", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Show Schedule",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/admin/schedules/{{scheduleId}}"
          }
        },
        {
          "name": "Update Schedule",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customer_address\": \"更新後的地址\",\n  \"task_details\": \"14離14000\"\n}"
            },
            "url": "{{baseUrl}}/admin/schedules/{{scheduleId}}"
          }
        },
        {
          "name": "Export Reports CSV",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/admin/reports/export?date_from=2026-06-29&date_to=2026-06-30"
          }
        },
        {
          "name": "List Reports",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/admin/reports"
          }
        },
        {
          "name": "List Reports (Filtered + Pagination)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/reports?date_from=2026-06-29&date_to=2026-06-30&user_id=3&page=1&per_page=15",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "reports"],
              "query": [
                { "key": "date_from", "value": "2026-06-29" },
                { "key": "date_to", "value": "2026-06-30" },
                { "key": "user_id", "value": "3" },
                { "key": "page", "value": "1" },
                { "key": "per_page", "value": "15" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Employee",
      "item": [
        {
          "name": "My Schedules (Today & Tomorrow)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/employee/schedules"
          }
        },
        {
          "name": "Submit Report",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"schedule_id\": {{scheduleId}},\n  \"completed_units\": 2,\n  \"collected_amount\": 22000\n}"
            },
            "url": "{{baseUrl}}/employee/reports"
          }
        }
      ]
    }
  ]
}
